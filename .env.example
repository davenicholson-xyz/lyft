# Drizzle
DATABASE_URL=local.db

# Anthropic (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=

# Strava OAuth (https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:5173/strava/callback

# API token for external integrations (iOS Shortcut etc) — any random string you choose
API_TOKEN=

# Strava webhook (any random string you choose)
STRAVA_WEBHOOK_TOKEN=
# Public URL of this app (no trailing slash), e.g. https://lyft.example.com
PUBLIC_URL=
